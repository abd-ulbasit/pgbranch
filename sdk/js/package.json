{
  "name": "pgbranch-test",
  "version": "0.1.0",
  "description": "A disposable copy-on-write Postgres branch for every test, backed by a pgbranch server",
  "license": "Apache-2.0",
  "type": "module",
  "main": "index.mjs",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.mjs"
    }
  },
  "files": [
    "index.mjs",
    "index.d.ts"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test test/*.test.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abd-ulbasit/pgbranch.git",
    "directory": "sdk/js"
  },
  "keywords": [
    "postgres",
    "testing",
    "database",
    "branch",
    "copy-on-write",
    "pgbranch"
  ]
}
